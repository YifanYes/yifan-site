---
import {
	DEFAULT_LOCALE,
	getAbsoluteUrl,
	getAlternateLinks,
	LOCALE_METADATA,
	type Locale,
} from '../lib/i18n';
import { SITE_COPY } from '../lib/ui';
import '../styles/workbench.css';

type Props = {
	title: string;
	description: string;
	locale?: Locale;
	path?: string;
};

const {
	title,
	description,
	locale = DEFAULT_LOCALE,
	path = Astro.url.pathname,
} = Astro.props;

const titleTemplate = SITE_COPY[locale].titleTemplate;
const pageTitle = titleTemplate.replace('%s', title);
const canonicalPath = path;
const canonicalUrl = getAbsoluteUrl(canonicalPath, Astro.site, Astro.url);
const alternateLinks = getAlternateLinks(canonicalPath);
---

<!doctype html>
<html lang={LOCALE_METADATA[locale].htmlLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<script is:inline>
			(() => {
				const storageKey = 'yifan-theme';
				const root = document.documentElement;
				const isTheme = (value) => value === 'light' || value === 'dark';
				let theme = null;

				try {
					const storedTheme = localStorage.getItem(storageKey);
					theme = isTheme(storedTheme) ? storedTheme : null;
				} catch {
					theme = null;
				}

				if (!theme) {
					theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				}

				root.dataset.theme = theme;
				root.style.colorScheme = theme;
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{alternateLinks.map((link) => (
			<link
				rel="alternate"
				hreflang={link.hreflang}
				href={getAbsoluteUrl(link.path, Astro.site, Astro.url)}
			/>
		))}
	</head>
	<body>
		<slot />
	</body>
</html>
