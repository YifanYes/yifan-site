---
import {
	DEFAULT_LOCALE,
	getAbsoluteUrl,
	getAlternateLinks,
	LOCALE_METADATA,
	type Locale,
} from '../lib/i18n';
import { SITE_COPY } from '../lib/ui';

type Props = {
	title: string;
	description: string;
	locale?: Locale;
	path?: string;
};

const {
	title,
	description,
	locale = DEFAULT_LOCALE,
	path = Astro.url.pathname,
} = Astro.props;

const titleTemplate = SITE_COPY[locale].titleTemplate;
const pageTitle = titleTemplate.replace('%s', title);
const canonicalPath = path;
const canonicalUrl = getAbsoluteUrl(canonicalPath, Astro.site, Astro.url);
const alternateLinks = getAlternateLinks(canonicalPath);
---

<!doctype html>
<html lang={LOCALE_METADATA[locale].htmlLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{alternateLinks.map((link) => (
			<link
				rel="alternate"
				hreflang={link.hreflang}
				href={getAbsoluteUrl(link.path, Astro.site, Astro.url)}
			/>
		))}
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		background: #f8f7f2;
		color: #171512;
		font-family:
			Atkinson Hyperlegible,
			Inter,
			Source Sans 3,
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			sans-serif;
	}

	:global(*),
	:global(*::before),
	:global(*::after) {
		box-sizing: border-box;
	}
</style>
