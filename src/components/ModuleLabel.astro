---
type Tone = 'default' | 'muted' | 'green' | 'red' | 'gold' | 'light';

type Props = {
	label?: string;
	tone?: Tone;
};

const { label, tone = 'default' } = Astro.props;
const className = `module-label module-label--${tone}`;
---

<p class={className}>
	<slot>{label}</slot>
</p>

<style>
	.module-label {
		color: var(--color-ink);
		font-family: var(--font-mono);
		font-size: 0.76rem;
		font-weight: 700;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.module-label--muted {
		color: var(--color-muted);
	}

	.module-label--green {
		color: var(--color-green);
	}

	.module-label--red {
		color: var(--color-red);
	}

	.module-label--gold {
		color: var(--color-gold);
	}

	.module-label--light {
		color: var(--color-close-up-text);
	}
</style>
