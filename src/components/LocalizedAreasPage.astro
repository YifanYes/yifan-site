---
import type { Locale } from '../lib/i18n';
import { AREA_DEFINITIONS } from '../lib/areas';
import { getLocalizedPath } from '../lib/i18n';
import { AREAS_COPY } from '../lib/ui';
import ModuleLabel from './ModuleLabel.astro';
import PageHeader from './PageHeader.astro';
import SiteShell from './SiteShell.astro';
import TaxonomyChip from './TaxonomyChip.astro';

type Props = {
	locale: Locale;
};

const { locale } = Astro.props;
const copy = AREAS_COPY[locale];
---

<SiteShell locale={locale}>
	<main class="areas-page">
		<PageHeader
			moduleLabel={copy.moduleLabel}
			kicker={copy.kicker}
			title={copy.title}
			description={copy.description}
		/>

		<section class="areas-page__list" aria-label={copy.listLabel.replace(' //', '')}>
			<ModuleLabel label={copy.listLabel} />

			<div class="areas-page__grid">
				{AREA_DEFINITIONS.map((area) => (
					<a class="areas-page__card" href={getLocalizedPath(locale, `/areas/${area.slug}`)}>
						<span>AREA.{area.slug.toUpperCase()} //</span>
						<strong>{area.title[locale]}</strong>
						<p>{area.description[locale]}</p>
						<div class="areas-page__chips">
							{area.focus[locale].map((focus) => <TaxonomyChip label={focus} />)}
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</SiteShell>

<style>
	.areas-page {
		padding-bottom: clamp(48px, 8vw, 96px);
	}

	.areas-page__list {
		margin-top: clamp(32px, 6vw, 64px);
	}

	.areas-page__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-top: 18px;
		border-top: 1px solid var(--color-ink);
		border-left: 1px solid var(--color-line);
	}

	.areas-page__card {
		display: grid;
		gap: 14px;
		min-width: 0;
		border-right: 1px solid var(--color-line);
		border-bottom: 1px solid var(--color-line);
		padding: 18px;
		text-decoration: none;
	}

	.areas-page__card > span {
		color: var(--color-red);
		font-family: var(--font-mono);
		font-size: 0.74rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.areas-page__card strong {
		font-family: var(--font-display);
		font-size: clamp(2rem, 4vw, 3.6rem);
		line-height: 0.95;
		text-transform: uppercase;
	}

	.areas-page__card p {
		max-width: 58ch;
		color: var(--color-muted);
		line-height: 1.6;
	}

	.areas-page__card:hover strong,
	.areas-page__card:focus-visible strong {
		color: var(--color-green);
	}

	.areas-page__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 8px;
	}

	@media (max-width: 760px) {
		.areas-page__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
