---
import {
	getAlternateLinks,
	getLocalizedPath,
	stripLocalePrefix,
	type AlternateLink,
	type Locale,
} from '../lib/i18n';
import { NAV_COPY } from '../lib/ui';
import ThemeToggle from './ThemeToggle.astro';

type Props = {
	locale: Locale;
	currentPath?: string;
	alternateLinks?: AlternateLink[];
};

const { locale, currentPath = Astro.url.pathname, alternateLinks } = Astro.props;
const copy = NAV_COPY[locale];
const normalizedCurrentPath = stripLocalePrefix(currentPath).replace(/\/$/, '') || '/';
const languageLinks = (alternateLinks ?? getAlternateLinks(currentPath)).filter(
	(link) => link.locale !== 'x-default',
);
const isActive = (path: string) => {
	const normalizedPath = path.replace(/\/$/, '') || '/';
	return normalizedPath === '/'
		? normalizedCurrentPath === '/'
		: normalizedCurrentPath === normalizedPath || normalizedCurrentPath.startsWith(`${normalizedPath}/`);
};
---

<div class="site-shell" data-sidebar-shell data-sidebar-state="expanded">
	<script is:inline>
		(() => {
			const storageKey = 'yifan-sidebar-state';
			const shell = document.currentScript?.parentElement;

			if (!shell) {
				return;
			}

			try {
				const storedState = localStorage.getItem(storageKey);

				if (storedState === 'collapsed' || storedState === 'expanded') {
					shell.dataset.sidebarState = storedState;
				}
			} catch {
				// Storage can be unavailable; the expanded rail remains fully usable.
			}
		})();
	</script>

	<a class="site-shell__skip" href="#main-content">{copy.skipLabel}</a>

	<button
		class="site-shell__restore"
		type="button"
		data-sidebar-toggle
		data-collapse-label={copy.sidebar.collapseLabel}
		data-expand-label={copy.sidebar.expandLabel}
		data-collapse-text={copy.sidebar.collapseText}
		data-expand-text={copy.sidebar.expandText}
		aria-label={copy.sidebar.expandLabel}
		aria-controls="site-shell-rail"
		aria-expanded="false"
	>
		<span aria-hidden="true">&gt;</span>
		<span>{copy.sidebar.expandText}</span>
	</button>

	<aside class="site-shell__rail" id="site-shell-rail" aria-label={copy.primaryLabel}>
		<div class="site-shell__rail-head">
			<a class="site-shell__mark" href={`/${locale}/`} aria-label={copy.homeLabel}>
				<img src="/logo.svg" alt="" width="48" height="48" />
			</a>

			<button
				class="site-shell__collapse"
				type="button"
				data-sidebar-toggle
				data-collapse-label={copy.sidebar.collapseLabel}
				data-expand-label={copy.sidebar.expandLabel}
				data-collapse-text={copy.sidebar.collapseText}
				data-expand-text={copy.sidebar.expandText}
				aria-label={copy.sidebar.collapseLabel}
				aria-controls="site-shell-rail"
				aria-expanded="true"
			>
				<span class="site-shell__collapse-text" data-sidebar-toggle-label>
					{copy.sidebar.collapseText}
				</span>
				<span class="site-shell__collapse-mark" data-sidebar-toggle-mark aria-hidden="true">&lt;</span>
			</button>
		</div>

		<nav class="site-shell__nav" aria-label={copy.primaryLabel}>
			{copy.links.map((link) => (
				<a
					href={getLocalizedPath(locale, link.path)}
					aria-label={link.label}
					aria-current={isActive(link.path) ? 'page' : undefined}
				>
					<span class="site-shell__nav-label">{link.label}</span>
				</a>
			))}
		</nav>

		<ThemeToggle
			label={copy.themeLabel}
			lightLabel={copy.theme.light}
			darkLabel={copy.theme.dark}
			switchToLightLabel={copy.theme.switchToLight}
			switchToDarkLabel={copy.theme.switchToDark}
		/>

		<nav class="site-shell__languages" aria-label={copy.languageLabel}>
			{languageLinks.map((link) => (
				<a
					href={link.path}
					aria-label={link.label}
					aria-current={link.locale === locale ? 'page' : undefined}
				>
					<span class="site-shell__nav-label">{link.label}</span>
				</a>
			))}
		</nav>
	</aside>

	<div class="site-shell__content" id="main-content">
		<slot />
	</div>
</div>

<script>
	const sidebarStorageKey = 'yifan-sidebar-state';
	const shells = document.querySelectorAll<HTMLElement>('[data-sidebar-shell]');
	const sidebarMobileQuery = window.matchMedia('(max-width: 920px)');

	const isSidebarState = (value: string | null): value is 'collapsed' | 'expanded' =>
		value === 'collapsed' || value === 'expanded';

	const getStoredSidebarState = () => {
		try {
			const storedState = localStorage.getItem(sidebarStorageKey);
			return isSidebarState(storedState) ? storedState : null;
		} catch {
			return null;
		}
	};

	const persistSidebarState = (state: 'collapsed' | 'expanded') => {
		try {
			localStorage.setItem(sidebarStorageKey, state);
		} catch {
			// Private browsing modes can reject storage; the in-page toggle should still work.
		}
	};

	const applySidebarState = (shell: HTMLElement, state: 'collapsed' | 'expanded') => {
		const toggles = shell.querySelectorAll<HTMLButtonElement>('[data-sidebar-toggle]');
		const rail = shell.querySelector<HTMLElement>('.site-shell__rail');
		const isCollapsed = state === 'collapsed';
		const shouldHideRail = isCollapsed && !sidebarMobileQuery.matches;

		shell.dataset.sidebarState = state;

		if (rail) {
			rail.toggleAttribute('inert', shouldHideRail);
			rail.setAttribute('aria-hidden', String(shouldHideRail));
		}

		toggles.forEach((toggle) => {
			const label = toggle.querySelector<HTMLElement>('[data-sidebar-toggle-label]');
			const mark = toggle.querySelector<HTMLElement>('[data-sidebar-toggle-mark]');

			toggle.setAttribute('aria-expanded', String(!shouldHideRail));
			toggle.setAttribute(
				'aria-label',
				shouldHideRail ? toggle.dataset.expandLabel ?? '' : toggle.dataset.collapseLabel ?? '',
			);

			if (label) {
				label.textContent = shouldHideRail
					? toggle.dataset.expandText ?? ''
					: toggle.dataset.collapseText ?? '';
			}

			if (mark) {
				mark.textContent = shouldHideRail ? '>' : '<';
			}
		});
	};

	shells.forEach((shell) => {
		const toggles = shell.querySelectorAll<HTMLButtonElement>('[data-sidebar-toggle]');
		const storedState = getStoredSidebarState();
		const currentState = shell.dataset.sidebarState ?? null;
		const initialState: 'collapsed' | 'expanded' = isSidebarState(currentState)
			? currentState
			: storedState ?? 'expanded';

		applySidebarState(shell, initialState);

		toggles.forEach((toggle) => {
			toggle.addEventListener('click', () => {
				const nextState = shell.dataset.sidebarState === 'collapsed' ? 'expanded' : 'collapsed';
				applySidebarState(shell, nextState);
				persistSidebarState(nextState);
			});
		});
	});

	sidebarMobileQuery.addEventListener('change', () => {
		shells.forEach((shell) => {
			const currentState = shell.dataset.sidebarState ?? null;
			applySidebarState(shell, isSidebarState(currentState) ? currentState : 'expanded');
		});
	});
</script>

<style>
	.site-shell {
		display: grid;
		grid-template-columns: minmax(148px, 180px) minmax(0, 1fr);
		gap: 28px;
		min-height: 100vh;
		border-top: 1px solid var(--color-ink);
		padding: 28px;
		transition:
			grid-template-columns 260ms ease,
			gap 260ms ease,
			padding-left 260ms ease;
	}

	.site-shell[data-sidebar-state='collapsed'] {
		grid-template-columns: 0 minmax(0, 1fr);
		gap: 0;
		padding-left: 52px;
	}

	.site-shell__skip {
		position: fixed;
		z-index: 20;
		top: 12px;
		left: 12px;
		padding: 10px 12px;
		background: var(--color-filled);
		color: var(--color-filled-text);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		text-transform: uppercase;
		transform: translateY(-160%);
	}

	.site-shell__skip:focus {
		transform: translateY(0);
	}

	.site-shell__restore {
		position: fixed;
		z-index: 15;
		top: 28px;
		left: 12px;
		display: inline-flex;
		align-items: center;
		gap: 8px;
		border: 1px solid var(--color-line-strong);
		border-radius: 2px;
		padding: 8px 10px;
		background: var(--color-bg);
		color: var(--color-ink);
		cursor: pointer;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1;
		text-transform: uppercase;
		opacity: 0;
		transform: translateX(-18px);
		transition:
			opacity 180ms ease,
			transform 260ms ease,
			visibility 0s linear 260ms,
			background-color var(--theme-transition-duration) var(--theme-transition-easing),
			border-color var(--theme-transition-duration) var(--theme-transition-easing),
			color var(--theme-transition-duration) var(--theme-transition-easing);
		visibility: hidden;
	}

	.site-shell[data-sidebar-state='collapsed'] .site-shell__restore {
		opacity: 1;
		transform: translateX(0);
		transition-delay: 120ms, 120ms, 0s, 0s, 0s, 0s;
		visibility: visible;
	}

	.site-shell__restore:hover,
	.site-shell__restore:focus-visible {
		border-color: var(--color-ink);
		color: var(--color-green);
	}

	.site-shell__rail {
		position: sticky;
		top: 28px;
		display: flex;
		flex-direction: column;
		gap: 22px;
		height: calc(100vh - 56px);
		border-right: 1px solid var(--color-line);
		padding: 0 28px 0 0;
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: 0.76rem;
		font-weight: 700;
		line-height: 1.3;
		min-width: 0;
		text-transform: uppercase;
		transition:
			opacity 180ms ease,
			transform 260ms ease,
			visibility 0s linear 0s;
	}

	.site-shell[data-sidebar-state='collapsed'] .site-shell__rail {
		opacity: 0;
		transform: translateX(-32px);
		transition:
			opacity 160ms ease,
			transform 260ms ease,
			visibility 0s linear 260ms;
		visibility: hidden;
		pointer-events: none;
	}

	.site-shell__rail-head {
		display: grid;
		gap: 18px;
		margin-bottom: 8px;
	}

	.site-shell__mark {
		display: block;
		width: 48px;
		height: 48px;
		text-decoration: none;
	}

	.site-shell__mark img {
		display: block;
		width: 100%;
		height: 100%;
		transition: filter var(--theme-transition-duration) var(--theme-transition-easing);
		object-fit: contain;
	}

	:global([data-theme='dark']) .site-shell__mark img {
		filter: invert(1);
	}

	.site-shell__collapse {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		width: 100%;
		border: 1px solid var(--color-line);
		border-radius: 2px;
		padding: 7px 8px;
		background: transparent;
		color: var(--color-muted);
		cursor: pointer;
		font: inherit;
		text-transform: uppercase;
	}

	.site-shell__collapse:hover,
	.site-shell__collapse:focus-visible {
		border-color: var(--color-ink);
		color: var(--color-green);
	}

	.site-shell__collapse-mark {
		font-size: 0.9rem;
		line-height: 1;
	}

	.site-shell[data-sidebar-state='collapsed'] .site-shell__collapse {
		opacity: 0;
	}

	.site-shell__nav,
	.site-shell__languages {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.site-shell__languages {
		margin-top: auto;
		padding-top: 22px;
		border-top: 1px solid var(--color-line);
	}

	.site-shell__rail a {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
	}

	.site-shell__rail a:hover,
	.site-shell__rail a:focus-visible,
	.site-shell__rail a[aria-current='page'] {
		color: var(--color-green);
	}

	.site-shell__content {
		min-width: 0;
		width: min(100%, var(--surface-width));
	}

	@media (max-width: 920px) {
		.site-shell {
			grid-template-columns: 1fr;
			gap: 24px;
			padding: 20px;
		}

		.site-shell[data-sidebar-state='collapsed'] {
			grid-template-columns: 1fr;
			gap: 24px;
			padding-left: 20px;
		}

		.site-shell__rail {
			position: static;
			display: grid;
			grid-template-columns: auto minmax(0, 1fr);
			height: auto;
			border-right: 0;
			border-bottom: 1px solid var(--color-line);
			padding: 0 0 18px;
		}

		.site-shell[data-sidebar-state='collapsed'] .site-shell__rail {
			opacity: 1;
			padding: 0 0 18px;
			transform: none;
			visibility: visible;
			pointer-events: auto;
		}

		.site-shell__restore {
			display: none;
		}

		.site-shell__rail-head {
			grid-column: 1;
			margin-bottom: 0;
		}

		.site-shell__mark {
			margin: 0;
		}

		.site-shell__collapse {
			display: none;
		}

		.site-shell__nav,
		.site-shell__languages {
			flex-flow: row wrap;
			align-items: center;
			justify-content: flex-end;
			gap: 10px 16px;
		}

		.site-shell__rail :global(.theme-toggle) {
			grid-column: 2;
			justify-self: end;
		}

		.site-shell__languages {
			grid-column: 1 / -1;
			margin-top: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-shell,
		.site-shell__rail,
		.site-shell__restore {
			transition: none;
		}
	}
</style>
