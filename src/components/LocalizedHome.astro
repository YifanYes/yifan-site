---
import ArchiveSpecPanel from './ArchiveSpecPanel.astro';
import ModuleLabel from './ModuleLabel.astro';
import PageHeader from './PageHeader.astro';
import SiteShell from './SiteShell.astro';
import TaxonomyChip from './TaxonomyChip.astro';
import { getLocalizedPath, type Locale } from '../lib/i18n';
import { HOME_COPY } from '../lib/ui';

type Props = {
	locale: Locale;
};

const { locale } = Astro.props;
const copy = HOME_COPY[locale];
---

<SiteShell locale={locale}>
	<main class="home-board" aria-labelledby="home-title">
		<PageHeader
			moduleLabel={copy.moduleLabel}
			kicker={copy.eyebrow}
			title={copy.title}
			description={copy.lede}
			headingId="home-title"
			titleScale="compact"
		/>

		<div class="home-board__grid">
			<section class="home-panel" aria-label={copy.statusLabel.replace(' //', '')}>
				<ArchiveSpecPanel label={copy.statusLabel} specs={copy.status} />
			</section>

			<section class="home-panel" aria-labelledby="home-social-title">
				<ModuleLabel label={copy.socialLabel} tone="green" />
				<h2 id="home-social-title">Links</h2>
				<div class="home-links">
					{copy.socialLinks.map((link) => (
						<a href={link.href} rel="me noopener noreferrer" target="_blank">
							{link.label}
						</a>
					))}
				</div>
			</section>
		</div>

		<section class="home-section" aria-labelledby="home-projects-title">
			<div class="home-section__header">
				<ModuleLabel label={copy.projectsLabel} tone="red" />
				<h2 id="home-projects-title">Projects</h2>
			</div>

			<div class="home-row-list">
				{copy.projects.map((project, index) => (
					<a
						class="home-row-link"
						href={project.href ?? getLocalizedPath(locale, project.path ?? '/projects')}
						target={project.href ? '_blank' : undefined}
						rel={project.href ? 'noopener noreferrer' : undefined}
					>
						<span>{String(index + 1).padStart(2, '0')}</span>
						<strong>{project.title}</strong>
						<small>{project.description}</small>
					</a>
				))}
			</div>
		</section>

		<section class="home-section" aria-labelledby="home-studying-title">
			<div class="home-section__header">
				<ModuleLabel label={copy.studyingLabel} tone="gold" />
				<h2 id="home-studying-title">Studying</h2>
			</div>

			<div class="home-chip-list">
				{copy.studying.map((topic) => <TaxonomyChip label={topic} />)}
			</div>
		</section>

		<section class="home-section" aria-labelledby="home-guide-title">
			<div class="home-section__header">
				<ModuleLabel label={copy.guideLabel} />
				<h2 id="home-guide-title">Site Map</h2>
			</div>

			<div class="home-guide-grid">
				{copy.guide.map((item) => (
					<a class="home-guide-card" href={getLocalizedPath(locale, item.path)}>
						<strong>{item.title}</strong>
						<span>{item.description}</span>
					</a>
				))}
			</div>
		</section>
	</main>
</SiteShell>

<style>
	.home-board {
		display: grid;
		align-content: start;
		min-height: calc(100vh - 56px);
		padding-bottom: clamp(48px, 8vw, 96px);
	}

	.home-board__grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(220px, 320px);
		gap: clamp(24px, 5vw, 64px);
		margin-top: clamp(30px, 5vw, 56px);
		border-top: 1px solid var(--color-ink);
		padding-top: 18px;
	}

	.home-panel {
		min-width: 0;
	}

	.home-panel .archive-spec-panel {
		padding-top: 0;
	}

	.home-panel h2,
	.home-section h2 {
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 3vw, 2.8rem);
		line-height: 0.98;
		text-transform: uppercase;
	}

	.home-panel h2 {
		margin-top: 16px;
	}

	.home-links {
		display: grid;
		margin-top: 18px;
		border-top: 1px solid var(--color-line);
	}

	.home-links a {
		border-bottom: 1px solid var(--color-line);
		padding: 12px 0;
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.home-section {
		display: grid;
		grid-template-columns: minmax(180px, 260px) minmax(0, 1fr);
		gap: clamp(24px, 5vw, 64px);
		margin-top: clamp(42px, 7vw, 82px);
		border-top: 1px solid var(--color-line-strong);
		padding-top: 18px;
	}

	.home-section__header {
		display: grid;
		align-content: start;
		gap: 18px;
	}

	.home-row-list {
		border-top: 1px solid var(--color-line);
	}

	.home-row-link {
		display: grid;
		grid-template-columns: 56px minmax(150px, 0.34fr) minmax(0, 1fr);
		gap: 18px;
		align-items: start;
		border-bottom: 1px solid var(--color-line);
		padding: 18px 0;
		text-decoration: none;
	}

	.home-row-link span,
	.home-row-link strong,
	.home-guide-card strong {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.35;
		text-transform: uppercase;
	}

	.home-row-link span {
		color: var(--color-muted);
	}

	.home-row-link small,
	.home-guide-card span {
		color: var(--color-muted);
		font-size: 0.92rem;
		line-height: 1.55;
	}

	.home-row-link:hover strong,
	.home-row-link:focus-visible strong,
	.home-guide-card:hover strong,
	.home-guide-card:focus-visible strong,
	.home-links a:hover,
	.home-links a:focus-visible {
		color: var(--color-green);
	}

	.home-chip-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		align-content: start;
	}

	.home-guide-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-top: 1px solid var(--color-line);
		border-left: 1px solid var(--color-line);
	}

	.home-guide-card {
		display: grid;
		gap: 28px;
		min-width: 0;
		border-right: 1px solid var(--color-line);
		border-bottom: 1px solid var(--color-line);
		padding: 18px;
		text-decoration: none;
	}

	@media (max-width: 860px) {
		.home-board__grid,
		.home-section {
			grid-template-columns: 1fr;
		}

		.home-row-link {
			grid-template-columns: 42px minmax(0, 1fr);
		}

		.home-row-link small {
			grid-column: 2;
		}
	}

	@media (max-width: 620px) {
		.home-guide-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
