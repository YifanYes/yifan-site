---
import ArchiveSpecPanel from './ArchiveSpecPanel.astro';
import ModuleLabel from './ModuleLabel.astro';
import PageHeader from './PageHeader.astro';
import SiteShell from './SiteShell.astro';
import { getLocalizedPath, type Locale } from '../lib/i18n';
import { HOME_COPY } from '../lib/ui';

type Props = {
	locale: Locale;
};

const { locale } = Astro.props;
const copy = HOME_COPY[locale];
---

<SiteShell locale={locale}>
	<main class="home-board" aria-labelledby="home-title">
		<PageHeader
			moduleLabel={copy.moduleLabel}
			kicker={copy.eyebrow}
			title={copy.title}
			description={copy.lede}
			headingId="home-title"
			titleScale="compact"
		/>

		<div class="home-sections">
			<section class="home-section" aria-labelledby="current-threads-title">
				<div class="home-section__header">
					<ModuleLabel label={`${copy.currentThreadsLabel} //`} tone="red" />
					<h2 id="current-threads-title">{copy.currentThreadsLabel}</h2>
				</div>

				<div class="home-thread-list">
					{copy.currentThreads.map((thread, index) => (
						<a class="home-row-link" href={getLocalizedPath(locale, thread.path)}>
							<span class="home-row-link__index">{String(index + 1).padStart(2, '0')}</span>
							<span>
								<strong>{thread.title}</strong>
								<span>{thread.description}</span>
							</span>
						</a>
					))}
				</div>
			</section>

			<section class="home-section" aria-labelledby="selected-artifacts-title">
				<div class="home-section__header">
					<ModuleLabel label={`${copy.selectedArtifactsLabel} //`} tone="green" />
					<h2 id="selected-artifacts-title">{copy.selectedArtifactsLabel}</h2>
				</div>

				<div class="home-artifact-grid">
					{copy.selectedArtifacts.map((artifact) => (
						<a class="home-artifact" href={getLocalizedPath(locale, artifact.path)}>
							<span>{artifact.type} //</span>
							<strong>{artifact.title}</strong>
							<small>{artifact.description}</small>
						</a>
					))}
				</div>
			</section>

			<section class="home-section" aria-labelledby="areas-title">
				<div class="home-section__header">
					<ModuleLabel label={`${copy.areasLabel} //`} tone="gold" />
					<h2 id="areas-title">{copy.areasLabel}</h2>
				</div>

				<div class="home-area-grid">
					{copy.areas.map((area) => (
						<a class="home-area-card" href={getLocalizedPath(locale, area.path)}>
							<span class="home-area-card__icon" aria-hidden="true">
								{area.icon === 'engineering' && (
									<svg viewBox="0 0 48 48">
										<path d="M13 17 6 24l7 7M35 17l7 7-7 7M28 10l-8 28" />
									</svg>
								)}
								{area.icon === 'product' && (
									<svg viewBox="0 0 48 48">
										<path d="M10 13h28v22H10zM16 20h16M16 27h10" />
									</svg>
								)}
								{area.icon === 'combat' && (
									<svg viewBox="0 0 48 48">
										<path d="M13 35 35 13M13 13l22 22M17 9l-8 8M31 39l8-8" />
									</svg>
								)}
								{area.icon === 'frameworks' && (
									<svg viewBox="0 0 48 48">
										<path d="M9 12h30M9 24h30M9 36h30M16 8v32M32 8v32" />
									</svg>
								)}
							</span>
							<strong>{area.title}</strong>
							<span>{area.description}</span>
						</a>
					))}
				</div>
			</section>

			<section class="home-section home-section--split" aria-labelledby="open-questions-title">
				<div class="home-section__header">
					<ModuleLabel label={`${copy.openQuestionsLabel} //`} tone="red" />
					<h2 id="open-questions-title">{copy.openQuestionsLabel}</h2>
				</div>

				<ArchiveSpecPanel
					label={`${copy.openQuestionsLabel} //`}
					specs={copy.openQuestions.map((question, index) => ({
						label: String(index + 1).padStart(2, '0'),
						value: question,
					}))}
				/>
			</section>
		</div>
	</main>
</SiteShell>

<style>
	.home-board {
		display: grid;
		align-content: start;
		min-height: calc(100vh - 56px);
	}

	.home-sections {
		display: grid;
		gap: clamp(42px, 7vw, 82px);
		padding: clamp(34px, 6vw, 68px) 0;
	}

	.home-section {
		display: grid;
		grid-template-columns: minmax(180px, 260px) minmax(0, 1fr);
		gap: clamp(24px, 5vw, 64px);
		border-top: 1px solid var(--color-line-strong);
		padding-top: 18px;
	}

	.home-section__header {
		display: grid;
		align-content: start;
		gap: 18px;
	}

	h2 {
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 3.2vw, 3rem);
		line-height: 0.98;
		text-transform: uppercase;
	}

	.home-thread-list {
		border-bottom: 1px solid var(--color-line);
	}

	.home-row-link {
		display: grid;
		grid-template-columns: 70px minmax(0, 1fr);
		gap: 22px;
		border-top: 1px solid var(--color-line);
		padding: 18px 0;
		text-decoration: none;
	}

	.home-row-link:hover strong,
	.home-row-link:focus-visible strong,
	.home-artifact:hover strong,
	.home-artifact:focus-visible strong,
	.home-area-card:hover strong,
	.home-area-card:focus-visible strong {
		color: var(--color-green);
	}

	.home-row-link__index,
	.home-artifact span {
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: 0.76rem;
		font-weight: 700;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.home-row-link strong,
	.home-artifact strong,
	.home-area-card strong {
		display: block;
		font-family: var(--font-mono);
		font-size: 0.9rem;
		line-height: 1.35;
		text-transform: uppercase;
	}

	.home-row-link span span,
	.home-artifact small,
	.home-area-card > span:last-child {
		display: block;
		max-width: 62ch;
		margin-top: 6px;
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.home-artifact-grid,
	.home-area-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-top: 1px solid var(--color-line);
		border-left: 1px solid var(--color-line);
	}

	.home-artifact,
	.home-area-card {
		min-width: 0;
		border-right: 1px solid var(--color-line);
		border-bottom: 1px solid var(--color-line);
		padding: 18px;
		text-decoration: none;
	}

	.home-artifact span {
		display: block;
		margin-bottom: 22px;
		color: var(--color-red);
	}

	.home-artifact small {
		font-size: 0.9rem;
	}

	.home-area-card {
		display: grid;
		gap: 14px;
	}

	.home-area-card__icon {
		display: grid;
		width: 48px;
		height: 48px;
		place-items: center;
		border: 1px solid var(--color-ink);
		background: var(--color-paper);
	}

	.home-area-card__icon svg {
		width: 30px;
		height: 30px;
		fill: none;
		stroke: var(--color-ink);
		stroke-linecap: square;
		stroke-linejoin: miter;
		stroke-width: 2.3;
	}

	.home-section--split .archive-spec-panel {
		padding-top: 0;
		border-top: 0;
	}

	@media (max-width: 820px) {
		.home-board {
			min-height: auto;
		}

		.home-section {
			grid-template-columns: 1fr;
		}

		.home-artifact-grid,
		.home-area-grid {
			grid-template-columns: 1fr;
		}

		.home-row-link {
			grid-template-columns: 48px minmax(0, 1fr);
		}
	}
</style>
