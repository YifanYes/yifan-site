---
import ArchiveSpecPanel from './ArchiveSpecPanel.astro';
import PageHeader from './PageHeader.astro';
import SiteShell from './SiteShell.astro';
import type { Locale } from '../lib/i18n';
import { HOME_COPY } from '../lib/ui';

type Props = {
	locale: Locale;
};

const { locale } = Astro.props;
const copy = HOME_COPY[locale];
const statusSpecs = copy.statusItems.map((item, index) => ({
	label: String(index + 1).padStart(2, '0'),
	value: item,
}));
---

<SiteShell locale={locale}>
	<main class="home-board" aria-labelledby="home-title">
		<PageHeader
			moduleLabel={copy.moduleLabel}
			kicker={copy.eyebrow}
			title={copy.title}
			description={copy.lede}
			headingId="home-title"
		/>

		<section class="home-status" aria-label={copy.statusLabel}>
			<ArchiveSpecPanel label={`${copy.statusLabel} //`} specs={statusSpecs} />
		</section>
	</main>
</SiteShell>

<style>
	.home-board {
		display: grid;
		align-content: center;
		min-height: calc(100vh - 56px);
	}

	.home-status {
		max-width: 520px;
		margin-top: 28px;
	}

	@media (max-width: 820px) {
		.home-board {
			align-content: start;
			min-height: auto;
		}
	}
</style>
