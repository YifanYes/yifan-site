---
import ModuleLabel from './ModuleLabel.astro';

type RelatedItem = {
	title: string;
	href: string;
	meta?: string;
	description?: string;
	reason?: string;
};

type Props = {
	label?: string;
	items?: RelatedItem[];
};

const { label = 'CONTINUE THREAD //', items = [] } = Astro.props;
---

<section class="related-content">
	<ModuleLabel label={label} />
	<div class="related-content__list">
		{items.map((item) => (
			<a class="related-content__item" href={item.href}>
				<span class="related-content__meta">{item.meta}</span>
				<strong>{item.title}</strong>
				{item.description && <span class="related-content__description">{item.description}</span>}
				{item.reason && <span class="related-content__reason">{item.reason}</span>}
			</a>
		))}
		{items.length === 0 && <slot />}
	</div>
</section>

<style>
	.related-content {
		border-top: 2px solid var(--color-ink);
		padding-top: 14px;
	}

	.related-content__list {
		margin-top: 16px;
		border-top: 1px solid var(--color-line);
	}

	.related-content__item {
		display: grid;
		grid-template-columns: 150px minmax(0, 0.8fr) minmax(0, 1fr);
		gap: 20px;
		border-bottom: 1px solid var(--color-line);
		padding: 18px 0;
		text-decoration: none;
	}

	.related-content__item:hover strong,
	.related-content__item:focus-visible strong {
		color: var(--color-green);
	}

	.related-content__meta,
	.related-content__reason {
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		line-height: 1.35;
		text-transform: uppercase;
	}

	strong {
		font-size: 1.08rem;
		line-height: 1.2;
	}

	.related-content__description {
		color: var(--color-muted);
		line-height: 1.45;
	}

	@media (max-width: 780px) {
		.related-content__item {
			grid-template-columns: 1fr;
			gap: 8px;
		}
	}
</style>
