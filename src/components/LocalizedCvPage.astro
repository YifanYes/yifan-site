---
import ArchiveSpecPanel from './ArchiveSpecPanel.astro';
import ModuleLabel from './ModuleLabel.astro';
import PageHeader from './PageHeader.astro';
import SiteShell from './SiteShell.astro';
import { CV_COPY } from '../lib/ui';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../lib/i18n';

type Props = {
	locale: Locale;
	entry: CollectionEntry<'cv'>;
	content: any;
};

const { locale, entry, content: Content } = Astro.props;
const copy = CV_COPY[locale];
const { data } = entry;
---

<SiteShell locale={locale}>
	<main class="cv-page">
		<PageHeader
			moduleLabel={copy.moduleLabel}
			kicker={copy.kicker}
			title={data.title}
			description={data.description}
		/>

		<section class="cv-page__profile">
			<div class="cv-page__spec" aria-label={copy.specLabel.replace(' //', '')}>
				<ArchiveSpecPanel label={copy.specLabel} specs={copy.specs} />
			</div>

			<aside class="cv-page__links" aria-label={copy.linksLabel.replace(' //', '')}>
				<ModuleLabel label={copy.linksLabel} tone="green" />
				<div>
					{copy.links.map((link) => (
						<a href={link.href} rel="me noopener noreferrer" target="_blank">
							{link.label}
						</a>
					))}
				</div>
			</aside>
		</section>

		<section class="cv-page__content" aria-label={copy.contentLabel}>
			<div class="cv-page__body workbench-prose">
				<Content />
			</div>
		</section>
	</main>
</SiteShell>

<style>
	.cv-page {
		padding-bottom: clamp(48px, 8vw, 96px);
	}

	.cv-page__profile {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(220px, 320px);
		gap: clamp(28px, 6vw, 80px);
		margin-top: clamp(32px, 6vw, 64px);
		border-top: 2px solid var(--color-ink);
		border-bottom: 1px solid var(--color-line);
		padding: 18px 0;
	}

	.cv-page__spec .archive-spec-panel {
		padding-top: 0;
	}

	.cv-page__links {
		border-left: 1px solid var(--color-line);
		padding-left: 22px;
	}

	.cv-page__links div {
		display: grid;
		margin-top: 18px;
		border-top: 1px solid var(--color-line);
	}

	.cv-page__links a {
		border-bottom: 1px solid var(--color-line);
		padding: 12px 0;
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.cv-page__links a:hover,
	.cv-page__links a:focus-visible {
		color: var(--color-green);
	}

	.cv-page__content {
		max-width: var(--article-width);
		margin: clamp(36px, 6vw, 72px) auto 0;
	}

	.cv-page__body {
		font-size: clamp(1.02rem, 1.4vw, 1.14rem);
		line-height: 1.8;
	}

	.cv-page__body :global(*) {
		overflow-wrap: anywhere;
	}

	.cv-page__body :global(p),
	.cv-page__body :global(ul),
	.cv-page__body :global(ol),
	.cv-page__body :global(blockquote) {
		margin: 0 0 1.25em;
	}

	.cv-page__body :global(h2),
	.cv-page__body :global(h3) {
		margin: 2.2em 0 0.7em;
		font-family: var(--font-display);
		line-height: 1;
		text-transform: uppercase;
	}

	.cv-page__body :global(h2) {
		border-top: 2px solid var(--color-ink);
		padding-top: 16px;
		font-size: clamp(2rem, 4vw, 3.4rem);
	}

	.cv-page__body :global(h2:first-child) {
		margin-top: 0;
	}

	.cv-page__body :global(h3) {
		font-size: clamp(1.45rem, 3vw, 2.15rem);
	}

	.cv-page__body :global(blockquote) {
		border-left: 3px solid var(--color-ink);
		padding: 0.1em 0 0.1em 1em;
		color: var(--color-muted);
		font-family: var(--font-typewriter);
	}

	.cv-page__body :global(li + li) {
		margin-top: 0.45em;
	}

	@media (max-width: 860px) {
		.cv-page__profile {
			grid-template-columns: 1fr;
		}

		.cv-page__links {
			border-left: 0;
			padding-left: 0;
		}
	}
</style>
