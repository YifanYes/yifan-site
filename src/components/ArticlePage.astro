---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { AlternateLink } from '../lib/i18n';
import ModuleLabel from './ModuleLabel.astro';
import RelatedContent from './RelatedContent.astro';
import SiteShell from './SiteShell.astro';
import TaxonomyChip from './TaxonomyChip.astro';
import TechnicalButton from './TechnicalButton.astro';

type Props = {
	entry: CollectionEntry<'articles'>;
	content: any;
	alternateLinks: AlternateLink[];
};

const { entry, content: Content, alternateLinks } = Astro.props;
const { data } = entry;
const slug = entry.id.split('/').slice(1).join('/');
const articlePath = `/${data.locale}/articles/${slug}/`;
const dateFormatter = new Intl.DateTimeFormat(data.locale, {
	year: 'numeric',
	month: 'long',
	day: '2-digit',
});
const formatLabel = (value: string) => value.replaceAll('-', ' ');
const formatTitleLabel = (value: string) =>
	formatLabel(value).replace(/\b\w/g, (letter) => letter.toUpperCase());
const sourceLabel = data.source ? `Original ${formatTitleLabel(data.source)} ->` : 'Original Source ->';
const metadata = [
	['Date', dateFormatter.format(data.date)],
	['Area', formatTitleLabel(data.area)],
	['Status', data.status ? formatTitleLabel(data.status) : 'Published'],
	['Language', data.locale],
];
const relatedCollections = await Promise.all([
	getCollection('articles'),
	getCollection('notes'),
	getCollection('documents'),
	getCollection('projects'),
	getCollection('now'),
]);
const routeSegments = {
	articles: 'articles',
	documents: 'documents',
	notes: 'notes',
	now: 'now',
	projects: 'projects',
};
const relatedEntries = new Map(
	relatedCollections.flat().map((relatedEntry) => [
		`${relatedEntry.collection}/${relatedEntry.id}`,
		relatedEntry,
	]),
);
const relatedItems = (data.related ?? [])
	.map((relatedRef) => {
		const relatedEntry = relatedEntries.get(relatedRef);

		if (!relatedEntry) {
			return undefined;
		}

		const relatedSlug = relatedEntry.id.split('/').slice(1).join('/');
		const routeSegment = routeSegments[relatedEntry.collection];

		return {
			title: relatedEntry.data.title,
			description: relatedEntry.data.description,
			href: `/${relatedEntry.data.locale}/${routeSegment}/${relatedSlug}/`,
			meta: `${relatedEntry.collection.toUpperCase()} // ${formatLabel(relatedEntry.data.area)}`,
		};
	})
	.filter((item) => item !== undefined);
---

<SiteShell locale={data.locale} currentPath={articlePath} alternateLinks={alternateLinks}>
	<main class="article-page">
		<header class="article-page__header">
			<div class="article-page__title">
				<ModuleLabel label="ARTICLE //"/>
				<h1>{data.title}</h1>
				<p>{data.description}</p>
			</div>

			<aside class="article-page__meta" aria-label="Article metadata">
				<ModuleLabel label="SPEC //"/>
				<dl>
					{metadata.map(([label, value]) => (
						<div>
							<dt>{label}</dt>
							<dd>{value}</dd>
						</div>
					))}
				</dl>
				<div class="article-page__chips" aria-label="Article tags">
					{data.tags.map((tag) => <TaxonomyChip label={formatLabel(tag)} />)}
				</div>
				{data.originalUrl && (
					<TechnicalButton href={data.originalUrl} label={sourceLabel} variant="quiet" />
				)}
			</aside>
		</header>

		{data.coverImage && (
			<figure class="article-page__cover">
				<img src={data.coverImage} alt="" loading="eager" decoding="async" />
			</figure>
		)}

		<div class="article-page__body">
			<Content />
		</div>

		<RelatedContent label="CONTINUE THREAD //" items={relatedItems}>
			<p class="article-page__related-empty">
				More related articles and notes will appear here as the archive grows.
			</p>
		</RelatedContent>
	</main>
</SiteShell>

<style>
	.article-page {
		padding-bottom: clamp(56px, 9vw, 112px);
	}

	.article-page__header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(220px, 320px);
		gap: clamp(28px, 6vw, 80px);
		border-bottom: 2px solid var(--color-ink);
		padding: clamp(28px, 7vw, 88px) 0 clamp(28px, 6vw, 64px);
	}

	.article-page__title {
		max-width: 820px;
	}

	.article-page__title h1 {
		margin-top: 16px;
		font-family: var(--font-display);
		font-size: clamp(3.4rem, 9vw, 8.8rem);
		letter-spacing: 0;
		line-height: 0.9;
		text-transform: uppercase;
	}

	.article-page__title p {
		max-width: 700px;
		margin-top: 18px;
		color: var(--color-muted);
		font-family: var(--font-typewriter);
		font-size: clamp(1rem, 1.5vw, 1.16rem);
		line-height: 1.7;
	}

	.article-page__meta {
		border-left: 1px solid var(--color-line);
		padding-left: 22px;
	}

	.article-page__meta dl {
		margin: 18px 0 0;
		border-top: 1px solid var(--color-line);
	}

	.article-page__meta div {
		border-bottom: 1px solid var(--color-line);
		padding: 12px 0;
	}

	.article-page__meta dt {
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.article-page__meta dd {
		margin: 5px 0 0;
		font-size: 0.92rem;
		line-height: 1.35;
		text-transform: capitalize;
	}

	.article-page__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin: 18px 0;
	}

	.article-page__cover {
		margin: 28px 0 0;
		border-top: 1px solid var(--color-ink);
		border-bottom: 1px solid var(--color-line);
		padding: 18px 0;
	}

	.article-page__cover img {
		display: block;
		width: 100%;
		max-height: 520px;
		object-fit: cover;
	}

	.article-page__body {
		max-width: var(--article-width);
		margin: clamp(36px, 6vw, 72px) auto;
		font-size: clamp(1.02rem, 1.4vw, 1.14rem);
		line-height: 1.8;
	}

	.article-page__body :global(*) {
		overflow-wrap: anywhere;
	}

	.article-page__body :global(p),
	.article-page__body :global(ul),
	.article-page__body :global(ol),
	.article-page__body :global(blockquote) {
		margin: 0 0 1.25em;
	}

	.article-page__body :global(h2),
	.article-page__body :global(h3) {
		margin: 2.2em 0 0.7em;
		font-family: var(--font-display);
		line-height: 1;
		text-transform: uppercase;
	}

	.article-page__body :global(h2) {
		border-top: 2px solid var(--color-ink);
		padding-top: 16px;
		font-size: clamp(2rem, 4vw, 3.4rem);
	}

	.article-page__body :global(h3) {
		font-size: clamp(1.45rem, 3vw, 2.15rem);
	}

	.article-page__body :global(blockquote) {
		border-left: 3px solid var(--color-ink);
		padding: 0.1em 0 0.1em 1em;
		color: var(--color-muted);
		font-family: var(--font-typewriter);
	}

	.article-page__body :global(li + li) {
		margin-top: 0.45em;
	}

	.article-page__body :global(hr) {
		margin: 2.5em 0;
		border: 0;
		border-top: 2px solid var(--color-ink);
	}

	.article-page__related-empty {
		margin-top: 16px;
		color: var(--color-muted);
	}

	@media (max-width: 860px) {
		.article-page__header {
			grid-template-columns: 1fr;
		}

		.article-page__meta {
			border-left: 0;
			padding-left: 0;
		}
	}
</style>
