---
import ModuleLabel from './ModuleLabel.astro';

type Props = {
	label?: string;
	title?: string;
};

const { label = 'CLOSE-UP //', title } = Astro.props;
const hasAside = Astro.slots.has('aside');
---

<section class="close-up-block">
	<div class="close-up-block__header">
		<ModuleLabel label={label} tone="light" />
		{title && <h2>{title}</h2>}
	</div>

	<div class:list={['close-up-block__body', hasAside && 'close-up-block__body--split']}>
		<div class="close-up-block__content">
			<slot />
		</div>
		{hasAside && <aside class="close-up-block__aside"><slot name="aside" /></aside>}
	</div>
</section>

<style>
	.close-up-block {
		border-top: 4px solid var(--color-red);
		background: var(--color-dark);
		color: var(--color-paper);
		padding: clamp(24px, 4vw, 40px);
	}

	.close-up-block__header {
		display: grid;
		gap: 18px;
	}

	h2 {
		max-width: 720px;
		font-family: var(--font-display);
		font-size: clamp(2rem, 5vw, 4.2rem);
		line-height: 0.95;
		text-transform: uppercase;
	}

	.close-up-block__body {
		margin-top: clamp(28px, 5vw, 52px);
		color: rgba(244, 240, 232, 0.78);
		font-size: 1rem;
		line-height: 1.65;
	}

	.close-up-block__body--split {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(220px, 320px);
		gap: clamp(24px, 5vw, 56px);
		align-items: start;
	}

	.close-up-block__aside {
		border-top: 1px solid rgba(244, 240, 232, 0.24);
		padding-top: 16px;
		color: rgba(244, 240, 232, 0.68);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		line-height: 1.55;
		text-transform: uppercase;
	}

	@media (max-width: 760px) {
		.close-up-block__body--split {
			grid-template-columns: 1fr;
		}
	}
</style>
