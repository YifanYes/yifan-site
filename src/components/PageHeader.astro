---
import ModuleLabel from './ModuleLabel.astro';

type Props = {
	moduleLabel: string;
	title: string;
	description?: string;
	kicker?: string;
	headingId?: string;
	titleScale?: 'default' | 'compact';
};

const { moduleLabel, title, description, kicker, headingId, titleScale = 'default' } = Astro.props;
---

<header class:list={['page-header', `page-header--${titleScale}`]}>
	<div class="page-header__main">
		<ModuleLabel label={moduleLabel} tone="green" />
		{kicker && <p class="page-header__kicker">{kicker}</p>}
		<h1 id={headingId}>{title}</h1>
	</div>

	{description && <p class="page-header__description">{description}</p>}
</header>

<style>
	.page-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(240px, 340px);
		gap: clamp(32px, 6vw, 80px);
		align-items: end;
		border-bottom: 1px solid var(--color-line);
		padding: clamp(36px, 7vw, 72px) 0 clamp(38px, 6vw, 58px);
	}

	.page-header__main {
		min-width: 0;
	}

	.page-header__kicker {
		margin-top: 44px;
		color: var(--color-muted);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		line-height: 1.3;
		text-transform: uppercase;
	}

	h1 {
		max-width: 900px;
		margin-top: 18px;
		font-family: var(--font-display);
		font-size: clamp(3rem, 7vw, 6.8rem);
		font-weight: 800;
		line-height: 0.92;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.page-header--compact h1 {
		max-width: 780px;
		font-size: clamp(2.9rem, 5.7vw, 5.5rem);
		line-height: 0.96;
	}

	.page-header__description {
		max-width: 340px;
		color: var(--color-muted);
		font-family: var(--font-typewriter);
		font-size: 0.95rem;
		line-height: 1.65;
	}

	@media (max-width: 820px) {
		.page-header {
			grid-template-columns: 1fr;
			gap: 28px;
		}

		.page-header__kicker {
			margin-top: 36px;
		}

		h1 {
			font-size: clamp(2.7rem, 15vw, 5.2rem);
			overflow-wrap: anywhere;
		}

		.page-header__description {
			max-width: 680px;
		}
	}
</style>
