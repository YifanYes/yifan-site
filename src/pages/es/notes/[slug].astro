---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import NotePage from '../../../components/NotePage.astro';
import Layout from '../../../layouts/Layout.astro';
import { getContentAlternates, getContentPath } from '../../../lib/content-alternates';

type NoteEntry = CollectionEntry<'notes'>;

export async function getStaticPaths() {
	const entries = await getCollection('notes', ({ data }) => data.locale === 'es' && !data.draft);

	return entries.map((entry) => ({
		params: { slug: entry.id.split('/').slice(1).join('/') },
		props: { entry },
	}));
}

const { entry } = Astro.props as { entry: NoteEntry };
const { Content, headings } = await render(entry);
const notes = await getCollection('notes');
const path = getContentPath(entry, 'notes');
const alternateLinks = getContentAlternates(entry, notes, 'notes');
---

<Layout
	title={entry.data.title}
	description={entry.data.description}
	locale="es"
	path={path}
	alternateLinks={alternateLinks}
>
	<NotePage entry={entry} content={Content} headings={headings} alternateLinks={alternateLinks} />
</Layout>
