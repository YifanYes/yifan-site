---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticlePage from '../../../components/ArticlePage.astro';
import Layout from '../../../layouts/Layout.astro';
import { getContentAlternates, getContentPath } from '../../../lib/content-alternates';

type ArticleEntry = CollectionEntry<'articles'>;

export async function getStaticPaths() {
	const entries = await getCollection('articles', ({ data }) => data.locale === 'es' && !data.draft);

	return entries.map((entry) => ({
		params: { slug: entry.id.split('/').slice(1).join('/') },
		props: { entry },
	}));
}

const { entry } = Astro.props as { entry: ArticleEntry };
const { Content, headings } = await render(entry);
const articles = await getCollection('articles');
const path = getContentPath(entry, 'articles');
const alternateLinks = getContentAlternates(entry, articles, 'articles');
---

<Layout
	title={entry.data.title}
	description={entry.data.description}
	locale="es"
	path={path}
	alternateLinks={alternateLinks}
>
	<ArticlePage entry={entry} content={Content} headings={headings} alternateLinks={alternateLinks} />
</Layout>
