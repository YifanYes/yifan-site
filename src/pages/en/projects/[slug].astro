---
import { getCollection, render } from 'astro:content';
import ArtifactPage from '../../../components/ArtifactPage.astro';
import Layout from '../../../layouts/Layout.astro';
import { getContentAlternates, getContentPath } from '../../../lib/content-alternates';

const locale = 'en';

export async function getStaticPaths() {
	const entries = await getCollection('projects', ({ data }) => data.locale === 'en' && !data.draft);

	return entries.map((entry) => ({
		params: { slug: entry.id.split('/').slice(1).join('/') },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const entries = await getCollection('projects', ({ data }) => !data.draft);
const path = getContentPath(entry, 'projects');
const alternateLinks = getContentAlternates(entry, entries, 'projects');
---

<Layout
	title={entry.data.title}
	description={entry.data.description}
	locale={locale}
	path={path}
	alternateLinks={alternateLinks}
>
	<ArtifactPage entry={entry} content={Content} alternateLinks={alternateLinks} />
</Layout>
